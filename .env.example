# ====================================================================
# Reclio environment configuration — copy to `.env` and fill in.
# Full documentation: https://anrew3.github.io/Reclio/configuration
# ====================================================================

# ---- Required API keys ---------------------------------------------
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
TMDB_API_KEY=
RECOMBEE_DATABASE_ID=
RECOMBEE_PRIVATE_TOKEN=
# Recombee region: us-west | eu-west | ap-se | ca-east
# Must match the region shown in your Recombee web UI URL
# (e.g. rapi-eu-west.recombee.com → eu-west).
RECOMBEE_REGION=us-west

# ---- Security ------------------------------------------------------
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
# Random 32-byte hex for session signing
SECRET_KEY=
# Token for /admin/* endpoints. Leave blank to disable admin entirely.
ADMIN_TOKEN=

# ---- App -----------------------------------------------------------
BASE_URL=https://reclio.p0xl.com
PORT=8000

# ====================================================================
# LLM (chat completions) — pick ONE provider via LLM_PROVIDER
# Options: ollama | claude | openai | openrouter | none
# Used for: row titles, personality blurbs, Ask Reclio chat,
#           intent classification, conversational mutations.
# ====================================================================
LLM_PROVIDER=ollama

# --- Ollama (default, self-hosted) ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b

# --- Anthropic Claude (LLM_PROVIDER=claude) ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5

# --- OpenAI (LLM_PROVIDER=openai, also used by EMBEDDING_PROVIDER=openai) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- OpenRouter (LLM_PROVIDER=openrouter) — one key, ~200 chat models ---
OPENROUTER_API_KEY=
# vendor/model format. Examples:
#   anthropic/claude-3.5-haiku     (cheap + fast, default)
#   anthropic/claude-3.5-sonnet    (higher quality)
#   openai/gpt-4o-mini             (OpenAI alternative)
#   meta-llama/llama-3.3-70b-instruct  (open weights)
#   google/gemini-2.0-flash-exp:free   (free tier)
OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# ====================================================================
# Embeddings (vector similarity) — independent from chat
# Options: auto | openai | ollama | local | none
# `auto` (default) follows LLM_PROVIDER:
#   ollama     → Ollama nomic-embed-text (768d)
#   openai     → OpenAI text-embedding-3-small (1536d, ★ recommended quality)
#   claude     → local sentence-transformers MiniLM (384d)
#   openrouter → local sentence-transformers MiniLM (384d)
#   none       → similarity rail empty
# Override here to mix-and-match (e.g. chat on Claude, embeddings on OpenAI).
# ====================================================================
EMBEDDING_PROVIDER=auto
# Optional override for the Ollama embedding model name (default: nomic-embed-text)
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ====================================================================
# Sync intervals (hours). Defaults are sensible — only override if
# you want different cadence behavior. Adaptive logic in user_sync.py
# decides the actual per-user cadence (hot 1h / default 6h / cold 24h /
# dormant 168h based on /feeds traffic + Trakt activity).
# ====================================================================
USER_SYNC_DEFAULT_INTERVAL_HOURS=8
USER_SYNC_HOT_INTERVAL_HOURS=4
USER_SYNC_COLD_INTERVAL_HOURS=24
USER_SYNC_HOT_THRESHOLD_PER_WEEK=14
USER_SYNC_COLD_THRESHOLD_PER_WEEK=3
USER_SYNC_SWEEP_INTERVAL_HOURS=1
CONTENT_SYNC_INTERVAL_HOURS=24
TOKEN_REFRESH_INTERVAL_HOURS=6

# ---- Storage ------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./data/db/reclio.db
CHROMA_PERSIST_DIR=./data/chroma
